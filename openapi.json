                                        }
                                    },
                                    "required": [
                                        "error"
                                    ]
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "summary": "Create a review",
                "tags": [
                    "Reviews"
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "description": "The email of the reviewer."
                                    },
                                    "name": {
                                        "type": "string",
                                        "maxLength": 60,
                                        "description": "The name of the reviewer."
                                    },
                                    "rating": {
                                        "type": "integer",
                                        "minimum": 1,
                                        "maximum": 5,
                                        "description": "The rating given by the reviewer."
                                    },
                                    "title": {
                                        "type": "string",
                                        "maxLength": 100,
                                        "description": "The title of the review."
                                    },
                                    "body": {
                                        "type": "string",
                                        "minLength": 10,
                                        "maxLength": 1000,
                                        "description": "The content of the review."
                                    },
                                    "product_ref": {
                                        "type": "string",
                                        "description": "The reference of the product for which to create a review."
                                    },
                                    "order_ref": {
                                        "type": "string",
                                        "description": "The reference of the order for which to create a review."
                                    }
                                },
                                "required": [
                                    "email",
                                    "name",
                                    "body"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Success",
